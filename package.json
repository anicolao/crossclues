{
  "name": "cross-clues-tabletop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "tsc && vite build",
    "check": "tsc --noEmit",
    "test:e2e": "npm run test:e2e:config && playwright test",
    "test:e2e:config": "tsx scripts/verify-zero-tolerance.ts",
    "test:e2e:update-snapshots": "playwright test --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
